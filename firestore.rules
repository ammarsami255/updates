rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function hasAuth() {
      return request.auth != null;
    }
    
    // Check if user is NOT anonymous (has verified identity)
    function hasVerifiedIdentity() {
      return hasAuth() && request.auth.token.email_verified == true;
    }
    
    // Check if user owns a resource (userId matches auth.uid)
    function isItemOwner(targetUserId) {
      return hasAuth() && request.auth.uid == targetUserId;
    }
    
    // Check if user has verified identity and owns resource
    function isVerifiedOwner(targetUserId) {
      return hasVerifiedIdentity() && request.auth.uid == targetUserId;
    }

    // ==================== SECURITY: BLOCK ANONYMOUS USERS ====================
    // Anonymous users (including unverified email) have very limited access
    
    // ==================== USER PROFILES ====================
    
    match /users/{userId} {
      // Only verified users can read/write their own profile
      allow read: if isVerifiedOwner(userId);
      allow write: if isVerifiedOwner(userId);
    }

    // ==================== LISTINGS ====================
    
    match /listings/{listingId} {
      // PUBLIC: Anyone can read active listings (includes anonymous for discoverability)
      allow read: if true;
      
      // Only VERIFIED users can create listings
      allow create: if hasVerifiedIdentity()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().size() <= 20
        && request.resource.data.title.size() <= 200
        && request.resource.data.description.size() <= 5000;
      
      // Only verified owners can update/delete their listings
      allow update, delete: if hasVerifiedIdentity()
        && resource.data.userId == request.auth.uid;
    }

    // ==================== CHATS ====================
    
    match /chats/{chatId} {
      // Allow get if document doesn't exist yet (for getOrCreate pattern)
      // Only verified users can access chats
      allow get: if hasVerifiedIdentity()
        && (resource == null || request.auth.uid in resource.data.participants);
      
      // Collection query (list): Must be verified
      allow list: if hasVerifiedIdentity() && request.auth.uid != null;
      
      // Create: must be verified, exactly 2 participants and be one of them
      allow create: if hasVerifiedIdentity()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      
      // Update/Delete: only verified participants can modify
      allow update, delete: if hasVerifiedIdentity()
        && request.auth.uid in resource.data.participants;
    }

    // ==================== MESSAGES ====================
    
    match /chats/{chatId}/messages/{messageId} {
      // Messages are protected by parent chat rules
      // For list queries: Firestore ensures the user has access to parent chat via arrayContains
      // For single doc access: verify user is verified
      
      // Read single document: Must be verified
      allow get: if hasVerifiedIdentity()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // Collection list: Verify parent chat membership via get()
      allow list: if hasVerifiedIdentity() && exists(/databases/$(database)/documents/chats/$(chatId)) 
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // Create: Must own the message and be verified
      allow create: if hasVerifiedIdentity()
        && request.resource.data.senderId == request.auth.uid;
      
      // Update: Verified participants can update (for isSeen/seenAt fields)
      allow update: if hasVerifiedIdentity()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // Delete: Only sender can delete their own messages
      allow delete: if hasVerifiedIdentity()
        && resource.data.senderId == request.auth.uid;
    }

    // ==================== NOTIFICATIONS ====================
    
    match /notifications/{userId} {
      // Only verified owner can read/write notifications
      allow read, write: if isVerifiedOwner(userId);
      
      match /items/{notificationId} {
        allow read, write: if isVerifiedOwner(userId);
      }
    }

    // ==================== SUPPORT ====================
    
    match /support/{id} {
      // Only verified users can create support tickets
      allow create: if hasVerifiedIdentity()
        && request.resource.data.userId == request.auth.uid;
      
      // Only verified owner can read their tickets
      allow read: if hasVerifiedIdentity()
        && resource.data.userId == request.auth.uid;
    }

    // ==================== SYSTEM COLLECTIONS ====================
    
    // Internal collections - no client access
    match /email_otps/{id} {
      allow read, write: if false;
    }
    
    match /rate_limits/{id} {
      allow read, write: if false;
    }
  }
}
